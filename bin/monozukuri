#!/usr/bin/env node
'use strict';
const { spawn } = require('node:child_process');
const { existsSync } = require('node:fs');
const { join, resolve } = require('node:path');
const { randomUUID } = require('node:crypto');

// Resolve the directory containing orchestrate.sh.
// Search order: Homebrew libexec sibling → repo root → repo scripts/ fallback.
function findScriptRoot() {
  const candidates = [
    resolve(__dirname, '..', 'libexec', 'monozukuri'),
    resolve(__dirname, '..'),
    resolve(__dirname, '..', 'scripts'),
  ];
  for (const dir of candidates) {
    if (existsSync(join(dir, 'orchestrate.sh'))) return dir;
  }
  throw new Error('Cannot find Monozukuri scripts. Check your installation.');
}

const SCRIPT_ROOT = findScriptRoot();
const orchestrate = join(SCRIPT_ROOT, 'orchestrate.sh');
const args = process.argv.slice(2);
const cmd = args[0] ?? '';

// MONOZUKURI_UI_DIST allows the Homebrew formula to inject the absolute path.
const uiDist =
  process.env.MONOZUKURI_UI_DIST ??
  resolve(__dirname, '..', 'ui', 'dist', 'index.js');

const UI_COMMANDS = new Set(['run', 'setup']);
const wantsUI =
  process.stdout.isTTY &&
  UI_COMMANDS.has(cmd) &&
  !args.includes('--no-ui') &&
  !args.includes('--json') &&
  !args.includes('--dry-run') &&
  !args.includes('--plan') &&
  existsSync(uiDist);

const runId = randomUUID();

const orchestrator = spawn('bash', [orchestrate, ...args], {
  env: { ...process.env, MONOZUKURI_HOME: SCRIPT_ROOT, MONOZUKURI_RUN_ID: runId },
  stdio: wantsUI ? ['inherit', 'pipe', 'inherit'] : 'inherit',
});

if (wantsUI) {
  const ui = spawn('node', [uiDist], {
    stdio: ['pipe', 'inherit', 'inherit'],
    env: {
      ...process.env,
      MONOZUKURI_ORCHESTRATOR_PID: String(orchestrator.pid),
      MONOZUKURI_RUN_ID: runId,
    },
  });
  orchestrator.stdout?.pipe(ui.stdin);
  ui.on('exit', () => orchestrator.kill('SIGINT'));
}

orchestrator.on('exit', (code) => process.exit(code ?? 0));
